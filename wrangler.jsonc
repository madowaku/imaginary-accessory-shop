{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mirage-market",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-16",
  "assets": { "not_found_handling": "single-page-application" },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mirage-market-db",
      "database_id": "local-development-placeholder",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    { "binding": "IMAGES", "bucket_name": "mirage-market-images" }
  ],
  "vars": {
    "APP_ENV": "development",
    "OPENAI_TEXT_MODEL": "gpt-5.6",
    "OPENAI_IMAGE_MODEL": "gpt-image-2",
    "SESSION_SECRET": "local-development-only-change-before-deploy"
  },
  "observability": { "enabled": true }
}
